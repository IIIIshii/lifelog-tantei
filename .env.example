# Gemini API Key (Get it from: https://aistudio.google.com/)
GEMINI_API_KEY=your_api_key_here

# Firebase の Web client ID（Googleログインに必須）
# Firebase Console で Google 認証を有効化すると自動生成される
# 「Web client (auto created by Google Service)」のクライアントID。
# android/app/google-services.json の client_type:3 の client_id と同じ値。
GOOGLE_WEB_CLIENT_ID=your_web_client_id_here.apps.googleusercontent.com